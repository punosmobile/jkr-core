    <layer id="v_velvoitteita_rikkovat_535b8ca6_b152_4cbb_8f08_42d3517b23ef"/>
    <layer id="OpenStreetMap_77e165a1_97a9_4a9d_8541_24b0caaafaec"/>
    <layer id="v_yli_5_asunnon_kohteet_a2f03cf8_e77e_46df_a510_0c1c1ff0be90"/>
    <layer id="Sekaj_tevelvoitteet_27b5b7e2_3af8_4b32_bbac_9746f79e8287"/>
    <layer id="Sekaj_tevelvoitteet_copy_5e22381f_d451_4c17_acd4_8cbbba3155d1"/>
    <layer id="Muovivelvoitteet_9161e30e_b7f8_401c_811e_b0ef0e37ab69"/>
    <layer id="Kartonkivelvoitteet_004531dc_f7d0_4303_ad97_340092e89ab5"/>
    <layer id="Lasipakkausvelvoitteet_8c6c357a_444a_417a_9991_3fdd48a4adca"/>
    <layer id="taajama_6b7a34ab_a583_40ed_a43a_ab30a3f6482b"/>
    <layer id="v_kohdehaku_0fc185ed_9e31_417c_b9a1_a9853e3281df"/>
    <layer id="v_velvoiteyhteenvetojen_kohteet_f6ac1d83_7e2a_4362_884a_a3546ac942da"/>
    <layer id="Sekaj_tevelvoitteet_1341b7c7_b46a_45a0_b999_d57d5e6cea8d"/>
    <layer id="Metallivelvoitteet_891d452a_d7e3_44df_8ae5_b84b0b8370a9"/>
    <layer id="_d6adfc86_fd6f_4ddf_808a_606ea0783d4d"/>
    <layer id="_8119911c_5fb2_4dde_82ea_25198719d8d2"/>
    <layer id="_07f1ed2d_20a9_4ea8_bfd5_7510e946d1c8"/>
    <layer id="_34188fde_0034_4a93_ad88_227a5e5c2968"/>
    <layer id="_f17e7861_c886_4a89_86ec_f2ddc7c1a358"/>
    <layer id="_fd1191c0_c2d2_49c3_a49d_cc199f338908"/>
